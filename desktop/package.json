{
  "name": "exampractice-electron-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron migration shell for the legacy Java exam system",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:desktop\"",
    "dev:renderer": "vite --config ./vite.config.mjs",
    "dev:desktop": "wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 node ./scripts/run-electron.js",
    "build:renderer": "vite build --config ./vite.config.mjs",
    "start": "node ./scripts/run-electron.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "pinia": "^2.2.4",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
